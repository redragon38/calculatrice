{
  "name": "monapp",
  "version": "1.0.0",
  "description": "Mon application Electron multiplateforme",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package:mac": "electron-packager . MonApp --platform=darwin --arch=x64 --overwrite",
    "package:win": "electron-packager . MonApp --platform=win32 --arch=x64 --overwrite",
    "package:all": "electron-packager . MonApp --platform=darwin,win32 --arch=x64 --overwrite"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-packager": "^17.1.1"
  }
}
